# InsForge API base URL — leave empty to use the page's own origin via the
# same-origin proxy (vercel.json rewrites in deploys, Vite dev proxy locally).
# Only set this for a direct cross-origin backend; note that then the auth
# refresh cookie is third-party and Safari/incognito log users out on reload.
VITE_INSFORGE_URL=
# InsForge functions host URL — leave empty for the same-origin /fn proxy.
VITE_INSFORGE_FUNCTIONS_URL=
# InsForge anonymous (publishable) key — required.
VITE_INSFORGE_ANON_KEY=
